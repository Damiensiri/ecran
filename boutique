<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<title>Services</title>

<style>

body{
margin:0;
font-family:Arial;
background:#f4f4f4;
}

header{
background:#181E3B;
color:white;
padding:15px;
display:flex;
justify-content:space-between;
align-items:center;
}

#panierBtn{
background:#2ecc71;
border:none;
padding:8px 14px;
border-radius:8px;
cursor:pointer;
}

.container{
padding:20px;
display:grid;
grid-template-columns:repeat(auto-fit,minmax(220px,1fr));
gap:20px;
}

.card{
background:white;
padding:20px;
border-radius:15px;
box-shadow:0 4px 10px rgba(0,0,0,0.1);
}

.card h3{
margin-top:0;
}

.price{
font-weight:bold;
margin:10px 0;
}

.card button{
background:#181E3B;
color:white;
border:none;
padding:8px 12px;
border-radius:8px;
cursor:pointer;
}

#panier{
position:fixed;
bottom:0;
left:0;
right:0;
background:white;
border-top:2px solid #ddd;
padding:15px;
display:none;
}

</style>
</head>

<body>

<header>

<h2>Services</h2>

<button id="panierBtn" onclick="togglePanier()">
Panier (<span id="count">0</span>)
</button>

</header>

<div class="container" id="services"></div>

<div id="panier">

<h3>Panier</h3>

<div id="listePanier"></div>

<p>Total : <span id="total">0</span> €</p>

<button onclick="commander()">Commander</button>

</div>

<script>

/* URL GOOGLE SHEET CSV */

const sheetURL="TON_URL_SHEET_CSV"

/* PANIER */

let panier=JSON.parse(localStorage.getItem("panier")||"[]")

updatePanier()

/* CHARGER SERVICES */

fetch(sheetURL)
.then(r=>r.text())
.then(data=>{

let lignes=data.split("\n").slice(1)

lignes.forEach(l=>{

let c=l.split(",")

if(c[4]!=="oui") return

let id=c[0]
let nom=c[1]
let desc=c[2]
let prix=parseFloat(c[3])

let card=document.createElement("div")
card.className="card"

card.innerHTML=`

<h3>${nom}</h3>
<p>${desc}</p>
<div class="price">${prix} €</div>

<button onclick="addPanier('${nom}',${prix})">
Ajouter
</button>

`

document.getElementById("services").appendChild(card)

})

})

/* AJOUT PANIER */

function addPanier(nom,prix){

panier.push({nom,prix})

localStorage.setItem("panier",JSON.stringify(panier))

updatePanier()

}

/* UPDATE PANIER */

function updatePanier(){

document.getElementById("count").innerText=panier.length

let html=""
let total=0

panier.forEach((p,i)=>{

html+=`
<div>
${p.nom} - ${p.prix} €
<button onclick="removeItem(${i})">X</button>
</div>
`

total+=p.prix

})

document.getElementById("listePanier").innerHTML=html
document.getElementById("total").innerText=total

}

/* SUPPRIMER */

function removeItem(i){

panier.splice(i,1)

localStorage.setItem("panier",JSON.stringify(panier))

updatePanier()

}

/* OUVRIR PANIER */

function togglePanier(){

let p=document.getElementById("panier")

p.style.display=p.style.display==="none"?"block":"none"

}

/* COMMANDER */

function commander(){

alert("Commande envoyée (EmailJS à brancher)")

}

</script>

</body>
</html>